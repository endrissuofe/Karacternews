# --- Database (PostgreSQL, local via Docker Compose) ---

# Password for the local Postgres container. Used by both docker-compose.yml
# and the DATABASE_URL below — must match.
POSTGRES_PASSWORD=changeme

# Full Postgres connection string Payload uses. Local dev via docker-compose.yml,
# user/db are "karacter" (adjust if you rename them).
DATABASE_URL=postgres://karacter:changeme@127.0.0.1:5432/karacter

# --- Payload ---

# Used to encrypt JWT tokens. Generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# Public URL of the site, no trailing slash. Used for CORS, links, etc.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron/scheduled jobs. Generate with: openssl rand -hex 32
CRON_SECRET=

# Secret used to validate draft-preview requests. Generate with: openssl rand -hex 32
PREVIEW_SECRET=

# --- Brevo (newsletter capture, Increment 4) ---

# API key from Brevo → Settings → SMTP & API → API keys. Server-side only.
BREVO_API_KEY=

# Optional: numeric ID of the Brevo contact list to add signups to.
# Leave empty to add contacts without a list.
BREVO_LIST_ID=

# --- Cloudflare R2 (podcast audio storage, Increment 5) ---
# S3-compatible credentials: Cloudflare dashboard → R2 → Manage API Tokens
# (Object Read & Write, scoped to the bucket). When these are empty, audio
# uploads fall back to local file storage (fine for dev/CI).

R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=karacter-media
# https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=

# --- Deployment (Increment 5.5, server only) ---

# Domain Caddy should serve with automatic HTTPS (e.g. karacter.ng).
# Leave empty on dev machines; before a domain exists, UAT runs on :80.
SITE_DOMAIN=
